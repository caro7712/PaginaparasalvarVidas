   
@{ 
    ViewData["Title"] = "Inicio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .hero {
        background: linear-gradient(135deg, #b30000, #ff1a1a);
        color: white;
        padding: 60px 20px;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .custom-card {
        border: none;
        border-radius: 20px;
        transition: all 0.3s ease-in-out;
    }

        .custom-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }

    .btn-red {
        background-color: #cc0000;
        color: white;
        border-radius: 30px;
    }

        .btn-red:hover {
            background-color: #990000;
            color: white;
        }
</style>

<div class="container mt-5 text-center">

    <div class="hero mb-5">
        <h1 class="display-3 fw-bold">
            🐾 SALVAR VIDAS
        </h1>

        <p class="lead mt-4 fs-4">
            Promovemos la adopción responsable y el rescate animal,
            generando impacto social real.
            Una plataforma moderna, rápida y preparada para crecer.
        </p>
    </div>

    <div class="row g-4 justify-content-center">

        <div class="col-md-4 col-lg-3">
            <div class="card custom-card shadow">
                <div class="card-body">
                    <h4 class="fw-bold text-danger">🐶 En Adopción</h4>
                    <a asp-controller="AnimalEnAdopcion" asp-action="Index"
                       class="btn btn-red btn-sm mt-3 px-4">
                        Ver más
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-3">
            <div class="card custom-card shadow">
                <div class="card-body">
                    <h4 class="fw-bold text-danger">🔎 Perdidos</h4>
                    <a asp-controller="AnimalPerdidoEncontrado" asp-action="Index"
                       class="btn btn-red btn-sm mt-3 px-4">
                        Ver más
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-3">
            <div class="card custom-card shadow">
                <div class="card-body">
                    <h4 class="fw-bold text-danger">🏠 En Tránsito</h4>
                    <a asp-controller="AnimalEnTransito" asp-action="Index"
                       class="btn btn-red btn-sm mt-3 px-4">
                        Ver más
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-3">
            <div class="card custom-card shadow">
                <div class="card-body">
                    <h4 class="fw-bold text-danger">🐾 Comunitarios</h4>
                    <a asp-controller="AnimalComunitario" asp-action="Index"
                       class="btn btn-red btn-sm mt-3 px-4">
                        Ver más
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-3">
            <div class="card custom-card shadow">
                <div class="card-body">
                    <h4 class="fw-bold text-danger">👨‍👩‍👧 Familias</h4>
                    <a asp-controller="Familia" asp-action="Index"
                       class="btn btn-red btn-sm mt-3 px-4">
                        Ver más
                    </a>
                </div>
            </div>
        </div>

    </div>

</div></div></div>