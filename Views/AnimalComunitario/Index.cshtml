@model IEnumerable<PaginaparaSalvarVidas.Models.AnimalComunitario>

@{
    ViewData["Title"] = "Animales Comunitarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Animales Comunitarios</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Voluntario"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">➕ Nuevo</a>
    </p>
}

<table id="tablaAnimalesComunitarios" class="table table-striped table-bordered table-hover datatable w-100">
    <thead>
        <tr>
            <th>Animal</th>
            <th>Lugar Habitual</th>
            <th>Apto para Adopción</th>

            @if (User.IsInRole("Admin") || User.IsInRole("Voluntario"))
            {
                <th>Acciones</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Animal?.Nombre</td>
                <td>@item.LugarHabitual</td>
                <td>@(item.AptoParaAdopcion ? "Sí" : "No")</td>

                @if (User.IsInRole("Admin") || User.IsInRole("Voluntario"))
                {
                    <td>
                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">✏ Editar</a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">🗑 Eliminar</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
