@model IEnumerable<PaginaparaSalvarVidas.Models.AnimalEnTransito>

@{
    ViewData["Title"] = "Animales en Tránsito";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Animales en Tránsito</h1>

<table class="table table-striped table-bordered table-hover datatable w-100">
    <thead>
        <tr>
            <th>Animal</th>
            <th>Familia</th>
            <th>Fecha Ingreso</th>
            <th>Fecha Salida</th>
            @if (User.IsInRole("Admin") || User.IsInRole("Voluntario"))
            {
                <th>Acciones</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Animal?.Nombre</td>
                <td>@item.Familia?.Nombre</td>
                <td>@item.FechaIngreso?.ToShortDateString()</td>
                <td>
                    @(item.FechaSalida.HasValue? item.FechaSalida.Value.ToShortDateString() : "—")
                </td>
                @if (User.IsInRole("Admin") || User.IsInRole("Voluntario"))
                {
                    <td>
                        <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">✏ Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">🗑 Eliminar</a>
                    </td>
                }

               
            </tr>
        }
    </tbody>
</table>