@model PaginaparaSalvarVidas.Models.AnimalVM
@using PaginaparaSalvarVidas.Models

@{
    ViewData["Title"] = "Crear Animal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <!-- Campos base Animal -->
    <div class="mb-3">
        <label asp-for="Animal.Nombre" class="form-label"></label>
        <input asp-for="Animal.Nombre" class="form-control" />
        <span asp-validation-for="Animal.Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Animal.Tipo" class="form-label"></label>
        <input asp-for="Animal.Tipo" class="form-control" />
        <span asp-validation-for="Animal.Tipo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Animal.Raza" class="form-label"></label>
        <input asp-for="Animal.Raza" class="form-control" />
        <span asp-validation-for="Animal.Raza" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Animal.Edad" class="form-label"></label>
        <input asp-for="Animal.Edad" type="number" class="form-control" />
        <span asp-validation-for="Animal.Edad" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Animal.Foto" class="form-label"></label>
        <input asp-for="Animal.Foto" class="form-control" />
        <span asp-validation-for="Animal.Foto" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Animal.Estado" class="form-label"></label>
        <select asp-for="Animal.Estado" class="form-select"
                asp-items="Html.GetEnumSelectList<EstadoAnimal>()" id="estadoSelect">
        </select>
        <span asp-validation-for="Animal.Estado" class="text-danger"></span>
    </div>

    <!-- ====== Sección ADOPCIÓN ====== -->
    <div id="seccionAdopcion" class="border rounded p-3 mb-3" style="display:none;">
        <h5>Datos de Adopción</h5>

        <div class="mb-3">
            <label asp-for="AnimalEnAdopcion.FamiliaId" class="form-label">Familia</label>
            <select asp-for="AnimalEnAdopcion.FamiliaId" class="form-select"
                    asp-items="Model.Familias">
                <option value="">-- Seleccione una familia --</option>
            </select>
            <span asp-validation-for="AnimalEnAdopcion.FamiliaId" class="text-danger"></span>
        </div>

        @* acá poné otros campos de adopción si existen *@
    </div>

    <!-- ====== Sección TRÁNSITO ====== -->
    <div id="seccionTransito" class="border rounded p-3 mb-3" style="display:none;">
        <h5>Datos de Tránsito</h5>

        <div class="mb-3">
            <label asp-for="AnimalEnTransito.FamiliaId" class="form-label">Familia (opcional)</label>
            <select asp-for="AnimalEnTransito.FamiliaId" class="form-select"
                    asp-items="Model.Familias">
                <option value="">-- (Opcional) --</option>
            </select>
            <span asp-validation-for="AnimalEnTransito.FamiliaId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="AnimalEnTransito.FechaIngreso" class="form-label"></label>
            <input asp-for="AnimalEnTransito.FechaIngreso" type="date" class="form-control" />
            <span asp-validation-for="AnimalEnTransito.FechaIngreso" class="text-danger"></span>
        </div>
    </div>

    <!-- ====== Sección COMUNITARIO ====== -->
    <div id="seccionComunitario" class="border rounded p-3 mb-3" style="display:none;">
        <h5>Datos de Comunitario</h5>

        <div class="mb-3">
            <label asp-for="AnimalComunitario.LugarHabitual" class="form-label"></label>
            <input asp-for="AnimalComunitario.LugarHabitual" class="form-control" />
            <span asp-validation-for="AnimalComunitario.LugarHabitual" class="text-danger"></span>
        </div>

        <div class="form-check">
            <input asp-for="AnimalComunitario.AptoParaAdopcion" class="form-check-input" />
            <label asp-for="AnimalComunitario.AptoParaAdopcion" class="form-check-label"></label>
        </div>
    </div>

    <button type="submit" class="btn btn-success">💾 Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">↩ Volver</a>
</form>

   @section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function setSectionEnabled(sectionId, enabled) {
            const section = document.getElementById(sectionId);

            // Mostrar / ocultar
            section.style.display = enabled ? "block" : "none";

            // Deshabilitar inputs para que NO se posteen
            section.querySelectorAll("input, select, textarea").forEach(el => {
                el.disabled = !enabled;
            });
        }

        function toggleSecciones() {
            const estado = document.getElementById("estadoSelect").value;

            const EN_ADOPCION = "@((int)EstadoAnimal.EnAdopcion)";
            const EN_TRANSITO = "@((int)EstadoAnimal.EnTransito)";
            const COMUNITARIO = "@((int)EstadoAnimal.Comunitario)";

            setSectionEnabled("seccionAdopcion", estado === EN_ADOPCION);
            setSectionEnabled("seccionTransito", estado === EN_TRANSITO);
            setSectionEnabled("seccionComunitario", estado === COMUNITARIO);
        }

        document.getElementById("estadoSelect").addEventListener("change", toggleSecciones);
        toggleSecciones();
    </script>

}
<div asp-validation-summary="All" class="text-danger mb-3"></div>