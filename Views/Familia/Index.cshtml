@model IEnumerable<PaginaparaSalvarVidas.Models.Familia>

@{
    ViewData["Title"] = "Familias";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Familias</h2>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Nueva Familia</a>
    </p>
}

<table class="table table-striped table-bordered table-hover datatable w-100">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Dirección</th>
            <th>Teléfono</th>
            @if (User.IsInRole("Admin") || User.IsInRole("Voluntario"))
            {
                <th>Acciones</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Direccion</td>
                <td>@item.Telefono</td>

                @if (User.IsInRole("Admin") || User.IsInRole("Voluntario"))
                {
                    <td>
                        <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                    </td>
                }
                
            </tr>
        }
    </tbody>
</table>