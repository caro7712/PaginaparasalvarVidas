@model IEnumerable<PaginaparaSalvarVidas.Models.AnimalEnTransito>

@{
    ViewData["Title"] = "Animales en Tránsito";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<h1>Animales en Tránsito</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">➕ Nuevo</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Animal</th>
            <th>Familia</th>
            <th>Fecha Ingreso</th>
            <th>Fecha Salida</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Animal?.Nombre</td>
                <td>@item.Familia?.Nombre</td>
                <td>@item.FechaIngreso.ToShortDateString()</td>
                <td>
                    @(item.FechaSalida.HasValue
                                    ? item.FechaSalida.Value.ToShortDateString()
                                    : "—")
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">✏ Editar</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">🗑 Eliminar</a>
            </td>
        </tr>
                }
    </tbody>
</table>