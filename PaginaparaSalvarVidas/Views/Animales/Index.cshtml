@model IEnumerable<PaginaparaSalvarVidas.Models.Animal>

@{
    ViewData["Title"] = "Listado de Animales";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<h1>Listado de Animales</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">➕ Crear Nuevo</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Tipo</th>
            <th>Raza</th>
            <th>Edad</th>
            <th>Foto</th>
            <th>Estado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Tipo</td>
                <td>@item.Raza</td>
                <td>@item.Edad</td>
                <td>
                    <img src="@item.Foto" width="80" />
                </td>
                <td>@item.Estado</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">✏ Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">🗑 Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table></table>